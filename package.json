{
  "name": "awf",
  "version": "0.1.0",
  "description": "Agentic workflow CLI — run loop over .awf/tasks.json",
  "packageManager": "pnpm@10.18.0",
  "type": "module",
  "bin": {
    "awf": "bin/awf.mjs"
  },
  "files": [
    "bin",
    "src",
    "spec"
  ],
  "scripts": {
    "awf": "node --import tsx src/cli.ts",
    "check": "tsgo --project tsconfig.json",
    "fmt": "oxfmt src bin spec",
    "fmt:check": "oxfmt --check src bin spec",
    "lint": "oxlint src bin",
    "lint:fix": "oxlint --fix src bin",
    "test": "node --import tsx --test src/*.test.ts"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
